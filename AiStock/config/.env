# ==================== 数据库连接（PostgreSQL） ====================
# 主数据库 - 指数/日线数据
DB_INDEX=postgresql+psycopg://sa:11111111@10.3.18.56/tdxIndex

# PE 数据库 - 指数估值历史数据
DB_INDEX_PE=postgresql+psycopg://sa:11111111@10.3.18.56/csiIndexPE

# 主数据库 - 个股/日线数据
DB_STOCK=postgresql+psycopg://sa:11111111@10.3.18.56/tdxStocks

# 主数据库 - 个股/资料数据
DB_STOCK_BASE=postgresql+psycopg://sa:11111111@10.3.18.56/StockBas

# 主数据库 - 个股/财务数据
DB_STOCK_FS=postgresql+psycopg://sa:11111111@10.3.18.56/tdxFS



# ==================== 外部 API Token ====================
# AkShare 代理（如果需要）
AKSHARE_PROXY=http://user:pass@proxy.example.com:8080

# Tushare Token（如果启用备用数据源）
TUSHARE_TOKEN=your_tushare_token_here

# ==================== 预警通知配置 ====================
# 企业微信/钉钉 webhook
ALERT_WEBHOOK_URL=https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=xxx
DINGTALK_WEBHOOK="https://oapi.dingtalk.com/robot/send?access_token=xxx"
# 邮件通知（可选）
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_USER=alerts@example.com
EMAIL_PASSWORD=EmailPassword123!

# ==================== 系统运行模式 ====================
# 开发环境：DEBUG=true，生产环境：DEBUG=false
DEBUG=false