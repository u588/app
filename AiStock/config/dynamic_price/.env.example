# ==================== 数据库连接（PostgreSQL） ====================
# 主数据库 - 指数/日线数据
DB_MAIN_URL=postgresql+psycopg://sa:YourSecurePassword123!@10.3.18.56/tdxIndex

# PE 数据库 - 估值历史数据
DB_PE_URL=postgresql+psycopg://sa:YourSecurePassword123!@10.3.18.56/tdxPE

# ==================== 外部 API Token ====================
# AkShare 代理（如果需要）
AKSHARE_PROXY=http://user:pass@proxy.example.com:8080

# Tushare Token（如果启用备用数据源）
TUSHARE_TOKEN=your_tushare_token_here

# ==================== 预警通知配置 ====================
# 企业微信/钉钉 webhook
ALERT_WEBHOOK_URL=https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=xxx

# 邮件通知（可选）
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_USER=alerts@example.com
EMAIL_PASSWORD=EmailPassword123!

# ==================== 系统运行模式 ====================
# 开发环境：DEBUG=true，生产环境：DEBUG=false
DEBUG=false